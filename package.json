{
  "name": "filepeek-ai",
  "version": "1.0.0",
  "description": "AI-powered file preview and analysis - See inside, instantly",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev:electron": "start landing-page.html && electron .",
    "test": "node --test test/*.test.js",
    "build": "electron-builder",
    "dist:dir": "set ELECTRON_BUILDER_DISABLE_BUILD_CACHE=true&& electron-builder --win --x64 --dir",
    "dist": "set ELECTRON_BUILDER_DISABLE_BUILD_CACHE=true&& electron-builder --win --x64",
    "dist:win": "set ELECTRON_BUILDER_DISABLE_BUILD_CACHE=true&& electron-builder --win --x64",
    "dist:portable": "set ELECTRON_BUILDER_DISABLE_BUILD_CACHE=true&& electron-builder --win portable",
    "register:context-menu": "powershell -ExecutionPolicy Bypass -File scripts/register-context-menu.ps1"
  },
  "keywords": [
    "electron",
    "ai",
    "file-preview",
    "gemini",
    "document-analysis"
  ],
  "author": "FilePeek AI Team",
  "license": "MIT",
  "dependencies": {
    "@e965/xlsx": "^0.20.3",
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.15.0",
    "docx": "^9.5.1",
    "dotenv": "^16.4.0",
    "jszip": "^3.10.0",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.6.205"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  },
    "build": {
    "appId": "com.filepeek.ai",
    "productName": "FilePeek AI",
    "compression": "store",
    "afterPack": "build/after-pack.js",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "role": "Viewer"
      },
      {
        "ext": "docx",
        "name": "Word Document",
        "role": "Viewer"
      },
      {
        "ext": "xlsx",
        "name": "Excel Workbook",
        "role": "Viewer"
      },
      {
        "ext": "txt",
        "name": "Text File",
        "role": "Viewer"
      },
      {
        "ext": "zip",
        "name": "ZIP Archive",
        "role": "Viewer"
      },
      {
        "ext": "jpg",
        "name": "JPEG Image",
        "role": "Viewer"
      },
      {
        "ext": "jpeg",
        "name": "JPEG Image",
        "role": "Viewer"
      },
      {
        "ext": "png",
        "name": "PNG Image",
        "role": "Viewer"
      },
      {
        "ext": "gif",
        "name": "GIF Image",
        "role": "Viewer"
      },
      {
        "ext": "webp",
        "name": "WebP Image",
        "role": "Viewer"
      },
      {
        "ext": "bmp",
        "name": "BMP Image",
        "role": "Viewer"
      },
      {
        "ext": "udf",
        "name": "UDF Document",
        "role": "Viewer"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signExts": [
        "!exe"
      ],
      "signAndEditExecutable": false,
      "icon": "build/icon.ico"
    },
    "nsis": {
      "include": "build/installer.nsh",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "icon": "build/icon.png"
    },
    "linux": {
      "icon": "build/icon.png"
    }
  }
}
